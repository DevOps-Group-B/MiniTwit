#!/bin/bash
# Transition to MASTER: claim DigitalOcean Floating IP for this droplet.
LOG_FILE="/var/log/keepalived-notify.log"
TOKEN_FILE="/etc/minitwit_do_token"
DO_METADATA_URL="http://169.254.169.254/metadata/v1/id"
FLOATING_IP="{{ floating_ip }}"

DO_TOKEN="${DO_API_TOKEN:-}"
if [[ -z "$DO_TOKEN" && -f "$TOKEN_FILE" ]]; then
  DO_TOKEN="$(cat "$TOKEN_FILE")"
fi

if [[ -z "$DO_TOKEN" ]]; then
  echo "$(date): MASTER transition on $(hostname), but DigitalOcean token is missing; skipped Floating IP API assignment for ${FLOATING_IP}" >> "$LOG_FILE"
  exit 0
fi

DROPLET_ID="$(curl -fsS "$DO_METADATA_URL" 2>/dev/null || true)"
if [[ -z "$DROPLET_ID" ]]; then
  echo "$(date): MASTER transition on $(hostname), failed to fetch droplet id from metadata service" >> "$LOG_FILE"
  exit 1
fi

API_RESPONSE="$(curl -fsS -X POST \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer ${DO_TOKEN}" \
  -d "{\"type\":\"assign\",\"droplet_id\":${DROPLET_ID}}" \
  "https://api.digitalocean.com/v2/floating_ips/${FLOATING_IP}/actions" 2>&1)"

if [[ $? -eq 0 ]]; then
  echo "$(date): Transitioned to MASTER on $(hostname), assigned Floating IP ${FLOATING_IP} to droplet ${DROPLET_ID}" >> "$LOG_FILE"
else
  echo "$(date): MASTER transition on $(hostname), failed to assign Floating IP ${FLOATING_IP}. API response: ${API_RESPONSE}" >> "$LOG_FILE"
  exit 1
fi
