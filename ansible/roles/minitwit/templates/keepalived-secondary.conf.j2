global_defs {
    script_user root
    enable_script_security
}

vrrp_script check_nginx {
    script "/usr/local/bin/check_nginx.sh"
    interval 2
    weight -60
    fall 3
    rise 2
}

vrrp_instance VI_1 {
    state BACKUP
    interface {{ keepalived_interface }}
    virtual_router_id {{ keepalived_virtual_router_id }}
    priority 100
    advert_int 1
    unicast_src_ip {{ hostvars[inventory_hostname].ansible_host }}
    unicast_peer {
        {{ hostvars[groups['minitwit_lb_primary'][0]].ansible_host }}
    }
    authentication {
        auth_type PASS
        auth_pass {{ keepalived_auth_pass }}
    }
    virtual_ipaddress {
        {{ keepalived_virtual_ip }}/{{ keepalived_virtual_ip_cidr }}
    }
    track_script {
        check_nginx
    }
    notify_master "/usr/local/bin/notify_primary.sh"
    notify_backup "/usr/local/bin/notify_backup.sh"
    notify_fault "/usr/local/bin/notify_fault.sh"
}
